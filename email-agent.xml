<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler import definition.
  Import via: schtasks /Create /XML email-agent.xml /TN "EmailAgent"
  Or: right-click Task Scheduler Library > Import Task...

  Adjust <Command> and <WorkingDirectory> to match your install path.
  For production, prefer NSSM which gives true service restart-on-failure behaviour.
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Autonomous email agent — polls Outlook via Graph API and executes Claude-decided actions.</Description>
    <Version>1.0</Version>
  </RegistrationInfo>

  <Triggers>
    <BootTrigger>
      <Enabled>true</Enabled>
      <Delay>PT30S</Delay>
    </BootTrigger>
  </Triggers>

  <Principals>
    <Principal id="Author">
      <!-- Run as a service account or the current user with highest privileges -->
      <LogonType>Password</LogonType>
      <RunLevel>HighestAvailable</RunLevel>
    </Principal>
  </Principals>

  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>10</Count>
    </RestartOnFailure>
  </Settings>

  <Actions Context="Author">
    <Exec>
      <!-- Update this path to your actual Bun install location -->
      <Command>C:\Users\user-pc\.bun\bin\bun.exe</Command>
      <Arguments>src/index.ts</Arguments>
      <!-- Update this path to your project directory -->
      <WorkingDirectory>C:\Users\user-pc\Desktop\ClaudeCodeTest\email-agent</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
